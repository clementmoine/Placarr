generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  guest
  user
  admin
}

enum Condition {
  new
  used
  damaged
}

enum Type {
  games
  movies
  musics
  books
  boardgames
}

enum AttachmentType {
  cover
  background
  screenshot
  artwork
  image
  logo
  audio
}

model Attachment {
  id         String         @id @default(cuid())
  type       AttachmentType
  title      String?
  duration   Int?
  url        String
  metadataId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  role       String?
  source     String?
  metadata   Metadata       @relation(fields: [metadataId], references: [id], onDelete: Cascade)

  @@index([metadataId])
}

model FieldEvidence {
  id              String        @id @default(cuid())
  field           String
  source          String
  value           String
  normalizedValue String?
  rawValue        Json?
  confidence      Float?
  priority        Int?
  sourceUrl       String?
  locale          String?
  region          String?
  itemId          String?
  metadataId      String?
  barcodeCacheId  Int?
  observedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  item            Item?         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  metadata        Metadata?     @relation(fields: [metadataId], references: [id], onDelete: Cascade)
  barcodeCache    BarcodeCache? @relation(fields: [barcodeCacheId], references: [id], onDelete: Cascade)

  @@index([field])
  @@index([source])
  @@index([itemId, field])
  @@index([metadataId, field])
  @@index([barcodeCacheId, field])
  @@index([observedAt])
}

model PriceOffer {
  id             String        @id @default(cuid())
  source         String
  productName    String?
  merchantName   String?
  condition      String?
  priceCents     Int
  currency       String        @default("EUR")
  shippingCents  Int?
  totalCents     Int?
  sourceUrl      String?
  availability   String?
  offerCount     Int?
  rawValue       Json?
  itemId         String?
  metadataId     String?
  barcodeCacheId Int?
  observedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  item           Item?         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  metadata       Metadata?     @relation(fields: [metadataId], references: [id], onDelete: Cascade)
  barcodeCache   BarcodeCache? @relation(fields: [barcodeCacheId], references: [id], onDelete: Cascade)

  @@index([source])
  @@index([itemId, source])
  @@index([metadataId, source])
  @@index([barcodeCacheId, source])
  @@index([condition, priceCents])
  @@index([observedAt])
}

model Shelf {
  id         String   @id @default(cuid())
  name       String
  slug       String?
  imageUrl   String?
  color      String?
  type       Type
  isPublic   Boolean  @default(true)
  cardFormat String   @default("default")
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      Item[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slug])
}

model Author {
  name     String     @id
  imageUrl String?
  metadata Metadata[] @relation("MetadataAuthors")
}

model Publisher {
  name     String     @id
  imageUrl String?
  metadata Metadata[] @relation("MetadataPublishers")
}

model Metadata {
  id            String          @id @default(cuid())
  title         String?
  duration      Int?
  pageCount     Int?
  tracksCount   Int?
  description   String?
  releaseDate   String?
  imageUrl      String?
  heroImageUrl  String?
  sourceType    Type
  sourceQuery   String
  lastFetched   DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  aliases       String?
  facts         String?
  attachments   Attachment[]
  fieldEvidence FieldEvidence[]
  priceOffers   PriceOffer[]
  items         Item[]
  authors       Author[]        @relation("MetadataAuthors")
  publishers    Publisher[]     @relation("MetadataPublishers")
}

model Item {
  id                 String          @id @default(cuid())
  name               String
  slug               String?
  description        String?
  imageUrl           String?
  barcode            String?
  condition          Condition
  metadataId         String?
  shelfId            String
  userId             String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  backgroundImageUrl String?
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shelf              Shelf           @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  metadata           Metadata?       @relation(fields: [metadataId], references: [id])
  fieldEvidence      FieldEvidence[]
  priceOffers        PriceOffer[]
  loans              LoanRequest[]

  @@index([shelfId])
  @@index([userId])
  @@index([metadataId])
  @@index([barcode])
  @@index([slug])
}

model RawName {
  id             Int          @id @default(autoincrement())
  value          String
  coverUrl       String?
  barcodeCacheId Int
  barcodeCache   BarcodeCache @relation(fields: [barcodeCacheId], references: [id], onDelete: Cascade)

  @@index([barcodeCacheId])
}

model BarcodeCache {
  id               Int             @id @default(autoincrement())
  barcode          String          @unique
  provider         String
  platformKey      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  shelfType        String?
  priceLastUpdated DateTime?
  priceNew         Int?
  priceUsed        Int?
  priceUsedCIB     Int?
  rawNames         RawName[]
  fieldEvidence    FieldEvidence[]
  priceOffers      PriceOffer[]
}

model UnresolvedBarcodeScan {
  id          Int      @id @default(autoincrement())
  barcode     String
  shelfType   String   @default("unknown")
  reason      String
  status      String   @default("open")
  seenCount   Int      @default(1)
  providers   String?
  rawNames    String?
  rawPayload  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@unique([barcode, shelfType, reason])
  @@index([barcode])
  @@index([status, lastSeenAt])
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String?       @unique
  image          String?
  role           UserRole      @default(guest)
  password       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          Item[]
  ownedLoans     LoanRequest[] @relation("OwnedLoans")
  requestedLoans LoanRequest[] @relation("RequestedLoans")
  shelves        Shelf[]
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoanRequest {
  id          String   @id @default(cuid())
  itemId      String
  requesterId String
  ownerId     String
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation("OwnedLoans", fields: [ownerId], references: [id], onDelete: Cascade)
  requester   User     @relation("RequestedLoans", fields: [requesterId], references: [id], onDelete: Cascade)
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([ownerId])
  @@index([requesterId])
  @@index([status])
}
